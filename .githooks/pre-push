#!/usr/bin/env bash
# Pre-push TDD gate: run the Playwright e2e suite locally before allowing a
# push (and therefore before any PR is opened from this branch).
#
# Bypasses for genuine exceptions (docs-only push, dep bump, broken local env):
#   SKIP_E2E=1 git push ...
#   git push --no-verify ...
set -euo pipefail

if [ "${SKIP_E2E:-0}" = "1" ]; then
  echo "↷ pre-push: SKIP_E2E=1, skipping Playwright e2e gate." >&2
  exit 0
fi

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

# Read stdin (push refs) — pre-push receives "<local_ref> <local_sha> <remote_ref> <remote_sha>" lines.
# If every pushed ref is a delete (local_sha == zero), skip — nothing to test.
zero="0000000000000000000000000000000000000000"
has_real_push=0
while read -r _local_ref local_sha _remote_ref _remote_sha; do
  if [ "$local_sha" != "$zero" ]; then
    has_real_push=1
  fi
done

if [ "$has_real_push" = "0" ]; then
  exit 0
fi

if ! command -v bun >/dev/null 2>&1; then
  echo "✖ pre-push: bun not found on PATH — install bun or bypass with SKIP_E2E=1." >&2
  exit 1
fi

# Feature-test floor: catch a whole feature folder shipping without any
# co-located tests. Cheap (~50ms) and runs before the slow e2e step.
echo "▶ pre-push: feature-test floor…" >&2
if ! "$repo_root/scripts/check-feature-tests.sh"; then
  cat <<'EOF' >&2

✖ pre-push: feature-test floor failed. Push aborted.

Genuine exception (e.g. generated stub folder):
  SKIP_FEATURE_TEST_FLOOR=1 git push ...
EOF
  exit 1
fi

# Unit tests: fast bun suite for the daemon. Catches behavioral regressions
# before the e2e step pays the Playwright boot cost.
echo "▶ pre-push: running daemon unit tests…" >&2
if ! bun run test; then
  echo "✖ pre-push: daemon unit tests failed. Push aborted." >&2
  exit 1
fi

echo "▶ pre-push: running Playwright e2e suite (SKIP_E2E=1 to bypass)…" >&2

if ! bun run test:e2e; then
  cat <<'EOF' >&2

✖ pre-push: Playwright e2e suite failed. Push aborted.

Inspect failures:
  apps/e2e/test-results/

Re-run locally:
  bun run test:e2e
  bun run test:e2e:ui   # interactive

Bypass for genuine exceptions (docs/dep-bump/broken-env):
  SKIP_E2E=1 git push ...
  git push --no-verify ...
EOF
  exit 1
fi

echo "✔ pre-push: e2e green." >&2
