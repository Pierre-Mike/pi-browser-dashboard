{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/main.ts",
    "src/main.tsx",
    "**/electrobun.config.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "global-setup.ts",
    "global-teardown.ts",
    "playwright.config.ts"
  ],
  "workspaces": {
    "packages": ["apps/*"]
  },
  "ignoreExports": [
    { "file": "apps/daemon/src/features/canvas/canvas.routes.ts", "exports": ["app"] },
    {
      "file": "apps/daemon/src/features/claude-config/claude-config.routes.ts",
      "exports": ["app"]
    },
    { "file": "apps/daemon/src/features/dispatch/dispatch.routes.ts", "exports": ["app"] },
    { "file": "apps/daemon/src/features/drops/drops.routes.ts", "exports": ["app"] },
    { "file": "apps/daemon/src/features/events/events.routes.ts", "exports": ["app"] },
    { "file": "apps/daemon/src/features/extensions/extensions.routes.ts", "exports": ["app"] },
    { "file": "apps/daemon/src/features/issue-driver/issue-driver.routes.ts", "exports": ["app"] },
    { "file": "apps/daemon/src/features/library/library.routes.ts", "exports": ["app"] },
    { "file": "apps/daemon/src/features/projects/projects.routes.ts", "exports": ["app"] },
    { "file": "apps/daemon/src/features/sessions/sessions.routes.ts", "exports": ["app"] },
    { "file": "apps/daemon/src/features/terminal/terminal.routes.ts", "exports": ["app"] },
    { "file": "apps/daemon/src/features/uploads/uploads.routes.ts", "exports": ["app"] }
  ],
  "duplicates": {
    "minOccurrences": 3
  },
  "rules": {}
}
