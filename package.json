{
  "name": "@pid/root",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run dev:daemon & bun run dev:web & wait",
    "dev:daemon": "cd apps/daemon && bun run dev",
    "dev:web": "cd apps/web && bun run dev",
    "test": "cd apps/daemon && bun test",
    "test:e2e": "cd apps/e2e && bun run test",
    "test:e2e:ui": "cd apps/e2e && bun run test:ui",
    "test:e2e:setup-auth": "cd apps/e2e && bun run setup:auth",
    "lint": "biome check --write .",
    "lint:ci": "biome ci .",
    "dead-code": "fallow dead-code",
    "dead-code:audit": "fallow audit",
    "check:feature-tests": "./scripts/check-feature-tests.sh",
    "pid-ext": "bun run scripts/pid-ext.ts",
    "prepare": "git config --unset core.hooksPath 2>/dev/null; bunx lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "fallow": "^2.88.1",
    "lefthook": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
